// CLMS — Calibration Laboratory Management System
// Multi-tenant schema: each Lab is an isolated tenant.
// SUPER_ADMIN is platform-level (labId = null); all other roles belong to a Lab.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum Role {
  SUPER_ADMIN
  LAB_ADMIN
  TECHNICAL_MANAGER
  CALIBRATION_ENGINEER
  SERVICE_ENGINEER
  DATA_ENTRY_OPERATOR
}

enum LabStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum JobStatus {
  RECEIVED
  WAITING
  ASSIGNED
  IN_CALIBRATION
  PENDING_REVIEW
  CORRECTION_REQUIRED
  APPROVED
  CERTIFICATE_GENERATED
  DELIVERED
  CLOSED
}

enum SignatureStage {
  ENGINEER
  REVIEWER
  TECHNICAL_MANAGER
  QUALITY_MANAGER
  FINAL_LOCK
}

enum CertificateType {
  NABL
  NON_NABL
  CALIBRATION_REPORT
  VERIFICATION_REPORT
  TEST_REPORT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  SUPERSEDED
  CONVERTED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
  CLOSED
}

enum DeliveryChallanStatus {
  DRAFT
  DISPATCHED
  DELIVERED
  CLOSED
  CANCELLED
}

// ───────────────────────── Labs (Tenants) ────────────────────────

model Lab {
  id                  String     @id @default(uuid())
  name                String
  accreditationNumber String?
  address             String?
  contactEmail        String?
  phone               String?
  website             String?
  city                String?
  state               String?
  pinCode             String?
  logoUrl             String?   // Base64 data-URL or object path for lab logo
  status              LabStatus  @default(PENDING)
  users               User[]
  customers           Customer[]
  instruments         Instrument[]
  jobs                Job[]
  invoices            Invoice[]
  quotations          Quotation[]
  tasks               Task[]
  ncrs                NCR[]
  environmentalRecords EnvironmentalRecord[]
  masterInstruments   MasterInstrument[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  rolePermissions     LabRolePermission[]
  labDocuments        LabDocument[]
  internalAudits      InternalAudit[]
  purchaseOrders      PurchaseOrder[]
  deliveryChallans    DeliveryChallan[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

// Per-lab, per-role permission toggles (LAB_ADMIN configures these)
model LabRolePermission {
  id            String  @id @default(uuid())
  labId         String
  lab           Lab     @relation(fields: [labId], references: [id], onDelete: Cascade)
  role          Role
  permissionKey String  // customers | instruments | jobs | certificates | billing |
                        // tasks | engineers | inventory | environmental | quality |
                        // audit | notifications
  granted       Boolean @default(true)

  @@unique([labId, role, permissionKey])
  @@index([labId, role])
}

// ──────────────────────── Identity & Access ──────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  role          Role     @default(DATA_ENTRY_OPERATOR)
  isActive      Boolean  @default(true)
  labId         String?  // null only for SUPER_ADMIN
  lab           Lab?     @relation(fields: [labId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  engineer      Engineer?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([labId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

// ─────────────────────────── CRM ─────────────────────────────────

model Customer {
  id               String           @id @default(uuid())
  labId            String
  lab              Lab              @relation(fields: [labId], references: [id])
  code             String
  name             String
  customerType     String           @default("BUSINESS")
  gstin            String?
  pan              String?
  email            String?
  phone            String?
  website          String?
  address          String?
  billingAddress   String?
  billingCity      String?
  billingState     String?
  billingPinCode   String?
  billingCountry   String?          @default("India")
  paymentTerms     String?
  creditLimit      Float            @default(0)
  creditDays       Int              @default(30)
  openingBalance   Float            @default(0)
  category         String?
  salesExecutive   String?
  tags             String[]
  notes            String?
  customerStatus   CustomerStatus   @default(ACTIVE)
  shippingAddresses CustomerAddress[]
  contacts         Contact[]
  instruments      Instrument[]
  jobs             Job[]
  jobBatches       JobBatch[]
  invoices         Invoice[]
  quotations       Quotation[]
  purchaseOrders   PurchaseOrder[]
  deliveryChallans DeliveryChallan[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([labId, code])
  @@index([labId])
}

model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String   @default("Shipping Address")
  address    String?
  city       String?
  state      String?
  pinCode    String?
  country    String?  @default("India")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Contact {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  designation String?
}

// ─────────────────────── Disciplines & Instruments ───────────────
// Disciplines are global reference data (shared across all labs)

model Discipline {
  id          String               @id @default(uuid())
  name        String               @unique
  code        String               @unique
  categories  InstrumentCategory[]
  instruments Instrument[]
}

model InstrumentCategory {
  id           String       @id @default(uuid())
  name         String
  disciplineId String
  discipline   Discipline   @relation(fields: [disciplineId], references: [id])
  instruments  Instrument[]
}

model Instrument {
  id            String              @id @default(uuid())
  labId         String
  lab           Lab                 @relation(fields: [labId], references: [id])
  customerId    String
  customer      Customer            @relation(fields: [customerId], references: [id])
  disciplineId  String?
  discipline    Discipline?         @relation(fields: [disciplineId], references: [id])
  categoryId    String?
  category      InstrumentCategory? @relation(fields: [categoryId], references: [id])
  name          String
  make          String?
  model         String?
  serialNumber  String?
  range         String?
  unit          String?
  leastCount    String?
  idNumber      String?
  labIdNo       String?   // Internal lab ID number for certificate
  quantity      Int?      // For sets (e.g., slip gauge sets)
  // Calibration interval & recall tracking
  calibrationIntervalMonths Int?
  lastCalibrationDate       DateTime?
  nextDueDate               DateTime?
  jobs          Job[]
  createdAt     DateTime            @default(now())

  @@index([labId])
}

// ─────────────────────── Master / Reference Standards ────────────

model MasterInstrument {
  id             String                   @id @default(uuid())
  labId          String
  lab            Lab                      @relation(fields: [labId], references: [id])
  name           String
  idNumber       String
  make              String?
  model             String?
  serialNumber      String?
  traceability      String?
  certificateNumber String?
  uncertainty       String?
  calibratedDate    DateTime?
  calibrationDue    DateTime?
  location          String?
  references        ReferenceStandardOnJob[]
  jobs              Job[]
  certificates      ReferenceStandardCertificate[]
  maintenance       ReferenceStandardMaintenance[]
  createdAt         DateTime                 @default(now())

  @@unique([labId, idNumber])
  @@index([labId])
}

// Versioned calibration-certificate uploads for a reference standard (3.1).
// The newest version is the active certificate; older versions are retained.
model ReferenceStandardCertificate {
  id                String           @id @default(uuid())
  masterId          String
  master            MasterInstrument @relation(fields: [masterId], references: [id], onDelete: Cascade)
  version           Int
  fileName          String
  fileType          String?          // MIME type (application/pdf, image/png, …)
  fileData          String           // data:<mime>;base64,<…> payload
  certificateNumber String?
  calibratedDate    DateTime?
  calibrationDue    DateTime?
  traceability      String?
  uncertainty       String?
  remarks           String?
  uploadedById      String?
  uploadedAt        DateTime         @default(now())

  @@index([masterId])
}

// Maintenance / service history for a reference standard (3.2).
model ReferenceStandardMaintenance {
  id          String           @id @default(uuid())
  masterId    String
  master      MasterInstrument @relation(fields: [masterId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String           // Service, Repair, Verification, …
  description String?
  performedBy String?
  createdAt   DateTime         @default(now())

  @@index([masterId])
}

// ───────────── Calibration scope: CMC & MPE masters (config-driven) ──────────

// NABL Scope / CMC master (Module 4.3 + 4.4). One row per
// discipline+parameter+range with the best CMC, method and scope metadata.
// Fetched automatically during calibration to validate against the lab's scope.
model CmcScope {
  id            String    @id @default(uuid())
  labId         String
  discipline    String
  parameter     String
  rangeMin      Float?
  rangeMax      Float?
  rangeText     String?   // Human-readable range, e.g. "0 to 25 mm"
  unit          String?
  cmc           String?   // Best CMC as printed, e.g. "±(0.5 + 0.3L) µm"
  cmcValue      Float?    // Numeric best CMC for automatic validation
  method        String?
  scope         String?   // NABL scope document reference
  revision      String?
  effectiveDate DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([labId])
}

// Maximum-permissible-error rule master (Module 4.2). Resolves the MPE for a
// point from discipline/parameter/range and optionally accuracy class and the
// reference standard, so calibration can auto-load the applicable MPE.
model MpeRule {
  id             String   @id @default(uuid())
  labId          String
  discipline     String
  parameter      String
  instrumentType String?
  accuracyClass  String?
  standard       String?
  rangeMin       Float?
  rangeMax       Float?
  unit           String?
  mpeValue       Float
  mpeIsPercent   Boolean  @default(false)
  resolution     Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([labId])
}

// ─────────────────────────── Jobs ────────────────────────────────

// A single customer intake grouping multiple instruments (Module 2.1).
// Each instrument in the batch becomes its own Job → its own calibration
// status, datasheets and certificate.
model JobBatch {
  id          String   @id @default(uuid())
  labId       String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  batchNumber String
  challanNo   String?
  poNumber    String?
  remarks     String?
  isOnsite    Boolean  @default(false)
  siteAddress String?
  receivedAt  DateTime @default(now())
  jobs        Job[]
  createdAt   DateTime @default(now())

  @@unique([labId, batchNumber])
  @@index([labId])
  @@index([customerId])
}

model Job {
  id           String     @id @default(uuid())
  jobNumber    String
  labId        String
  lab          Lab        @relation(fields: [labId], references: [id])
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  // Optional grouping: a single customer intake of multiple instruments creates
  // one JobBatch with one Job (and one certificate) per instrument.
  batchId      String?
  batch        JobBatch?  @relation(fields: [batchId], references: [id])
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id])
  engineerId   String?
  engineer     Engineer?  @relation(fields: [engineerId], references: [id])
  status       JobStatus  @default(RECEIVED)
  receivedAt   DateTime   @default(now())
  dueDate      DateTime?
  remarks      String?
  // Administrative fields (for certificate)
  challanNo            String?
  poNumber             String?
  conditionOfItem      String?   @default("OK (As Received)")
  calibrationProcedureNo  String?
  referenceDocumentNo  String?
  calibrationProcedure String?   // Procedure description text
  // Locked calibration procedure (set at job creation, immutable thereafter)
  procedureId          String?   // ID from the frontend procedures library
  procedureRangeIndex  Int?      // Selected range index (0-based); null = first/only range
  unitOfMeasurement    String?   // Unit locked at job creation
  // Master instrument selected at job creation
  masterInstrumentId   String?
  masterInstrument     MasterInstrument? @relation(fields: [masterInstrumentId], references: [id])
  // Onsite calibration
  isOnsite     Boolean    @default(false)
  siteAddress  String?
  siteContact  String?
  visitDate    DateTime?
  datasheets   Datasheet[]
  certificate  Certificate?
  references   ReferenceStandardOnJob[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([labId, jobNumber])
  @@index([labId])
  @@index([batchId])
}

model ReferenceStandardOnJob {
  jobId    String
  masterId String
  job      Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  master   MasterInstrument @relation(fields: [masterId], references: [id])

  @@id([jobId, masterId])
}

// ─────────────────────── Datasheet engine ────────────────────────

model Datasheet {
  id            String             @id @default(uuid())
  jobId         String
  job           Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  templateName  String
  version       Int                @default(1)
  environmental Json?
  observations  Observation[]
  uncertainty   UncertaintyBudget?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Observation {
  id            String    @id @default(uuid())
  datasheetId   String
  datasheet     Datasheet @relation(fields: [datasheetId], references: [id], onDelete: Cascade)
  pointLabel    String?
  unit          String?
  nominal       Float?
  standardValue Float?
  observedValue Float?
  correction    Float?
  error         Float?
  data          Json?
}

// ─────────────────────── Uncertainty engine ──────────────────────

model UncertaintyBudget {
  id                  String                 @id @default(uuid())
  datasheetId         String                 @unique
  datasheet           Datasheet              @relation(fields: [datasheetId], references: [id], onDelete: Cascade)
  combinedUncertainty Float?
  coverageFactor      Float?                 @default(2)
  expandedUncertainty Float?
  confidenceLevel     Float?                 @default(95.45)
  parameters          UncertaintyParameter[]
}

model UncertaintyParameter {
  id             String            @id @default(uuid())
  budgetId       String
  budget         UncertaintyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  source         String
  type           String
  value          Float
  distribution   String?
  divisor        Float?
  sensitivity    Float?            @default(1)
  degreesFreedom Float?
  unit           String?
}

// ─────────────────────── Certificates & signatures ───────────────

model Certificate {
  id                String             @id @default(uuid())
  jobId             String             @unique
  job               Job                @relation(fields: [jobId], references: [id])
  certificateNumber String             @unique
  type              CertificateType    @default(NABL)
  issueDate         DateTime           @default(now())
  qrHash            String?
  pdfPath           String?
  isLocked          Boolean            @default(false)
  decisionRule      String?
  // Revision control: 0 = original issue, 1 = Revision-1, etc.
  // The certificate row always holds the LATEST revision; superseded revisions
  // are archived (read-only) in CertificateRevision.
  revision          Int                @default(0)
  revisionReason    String?
  signatures        DigitalSignature[]
  revisions         CertificateRevision[]
  createdAt         DateTime           @default(now())
}

// Immutable archive of a superseded certificate revision. One row is written
// for each revision step, preserving the full history of a certificate.
model CertificateRevision {
  id                String          @id @default(uuid())
  certificateId     String
  certificate       Certificate     @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  revision          Int
  certificateNumber String
  type              CertificateType
  issueDate         DateTime
  qrHash            String?
  decisionRule      String?
  revisionReason    String?
  // Snapshot of the certificate state (signatures, lock flag) at archive time.
  snapshot          Json?
  archivedAt        DateTime        @default(now())

  @@index([certificateId])
}

model DigitalSignature {
  id            String         @id @default(uuid())
  certificateId String
  certificate   Certificate    @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  stage         SignatureStage
  signedById    String
  signedByName  String
  signatureHash String
  signedAt      DateTime       @default(now())
}

// ─────────────────────── Engineers & Tasks ───────────────────────

model Engineer {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  employeeCode   String   @unique
  skills         String[]
  authorizations String[]
  jobs           Job[]
  tasks          Task[]
}

model Task {
  id          String    @id @default(uuid())
  labId       String
  lab         Lab       @relation(fields: [labId], references: [id])
  title       String
  description String?
  status      String    @default("PENDING")
  engineerId  String?
  engineer    Engineer? @relation(fields: [engineerId], references: [id])
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  @@index([labId])
}

// ─────────────────────────── Billing ─────────────────────────────

model Invoice {
  id               String        @id @default(uuid())
  labId            String
  lab              Lab           @relation(fields: [labId], references: [id])
  invoiceNumber    String        @unique
  customerId       String
  customer         Customer      @relation(fields: [customerId], references: [id])
  status           InvoiceStatus @default(DRAFT)
  lineItems        Json          @default("[]")
  amount           Float         @default(0)
  discountTotal    Float         @default(0)
  taxAmount        Float         @default(0)
  cgst             Float         @default(0)
  sgst             Float         @default(0)
  igst             Float         @default(0)
  totalAmount      Float         @default(0)
  dueDate          DateTime?
  placeOfSupply    String?
  customerPoNumber String?
  paymentTerms     String?
  termsConditions  String?
  notes            String?
  linkedQuotationId String?
  linkedChallanId  String?
  payments         Payment[]
  issueDate        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([labId])
}

model Quotation {
  id               String          @id @default(uuid())
  labId            String
  lab              Lab             @relation(fields: [labId], references: [id])
  quoteNumber      String
  customerId       String
  customer         Customer        @relation(fields: [customerId], references: [id])
  status           QuotationStatus @default(DRAFT)
  subject          String?
  reference        String?
  contactPerson    String?
  items            Json            @default("[]")
  amount           Float           @default(0)
  discountTotal    Float           @default(0)
  taxRate          Float           @default(18)
  taxAmount        Float           @default(0)
  cgst             Float           @default(0)
  sgst             Float           @default(0)
  igst             Float           @default(0)
  totalAmount      Float           @default(0)
  validUntil       DateTime?
  deliveryTerms    String?
  deliveryPeriod   String?
  termsConditions  String?
  placeOfSupply    String?
  notes            String?
  linkedInvoiceId  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([labId, quoteNumber])
  @@index([labId])
}

model PurchaseOrder {
  id              String              @id @default(uuid())
  labId           String
  lab             Lab                 @relation(fields: [labId], references: [id])
  poNumber        String
  poDate          DateTime            @default(now())
  supplierId      String
  supplier        Customer            @relation(fields: [supplierId], references: [id])
  supplierRef     String?
  contactPerson   String?
  expectedDate    DateTime?
  deliveryAddress String?
  paymentTerms    String?
  status          PurchaseOrderStatus @default(DRAFT)
  lineItems       Json                @default("[]")
  subTotal        Float               @default(0)
  discountTotal   Float               @default(0)
  cgst            Float               @default(0)
  sgst            Float               @default(0)
  igst            Float               @default(0)
  totalAmount     Float               @default(0)
  notes           String?
  internalNotes   String?
  cancelReason    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([labId, poNumber])
  @@index([labId])
}

model DeliveryChallan {
  id                String                @id @default(uuid())
  labId             String
  lab               Lab                   @relation(fields: [labId], references: [id])
  challanNumber     String
  challanDate       DateTime              @default(now())
  challanType       String                @default("SALE")
  customerId        String
  customer          Customer              @relation(fields: [customerId], references: [id])
  contactPerson     String?
  deliveryAddress   String?
  linkedQuotationId String?
  linkedInvoiceId   String?
  lineItems         Json                  @default("[]")
  status            DeliveryChallanStatus @default(DRAFT)
  dispatchDate      DateTime?
  expectedDelivery  DateTime?
  transportMode     String?
  transporterName   String?
  vehicleNumber     String?
  driverName        String?
  driverMobile      String?
  lrNumber          String?
  lrDate            DateTime?
  eWayBillNumber    String?
  numberOfPackages  Int?
  weightKg          Float?
  remarks           String?
  podUploaded       Boolean               @default(false)
  cancelReason      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([labId, challanNumber])
  @@index([labId])
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  method    String?
  paidAt    DateTime @default(now())
}

// ─────────────────── Environmental & Quality (NCR/CAPA) ───────────

model EnvironmentalRecord {
  id          String   @id @default(uuid())
  labId       String
  lab         Lab      @relation(fields: [labId], references: [id])
  location    String
  temperature Float?
  humidity    Float?
  pressure    Float?
  operator    String?
  recordedAt  DateTime @default(now())

  @@index([labId])
}

model NCR {
  id          String   @id @default(uuid())
  labId       String
  lab         Lab      @relation(fields: [labId], references: [id])
  reference   String
  description String
  status      String   @default("OPEN")
  raisedById  String?
  capa        CAPA?
  createdAt   DateTime @default(now())

  @@unique([labId, reference])
  @@index([labId])
}

model CAPA {
  id               String   @id @default(uuid())
  ncrId            String   @unique
  ncr              NCR      @relation(fields: [ncrId], references: [id], onDelete: Cascade)
  rootCause        String?
  correctiveAction String?
  preventiveAction String?
  status           String   @default("OPEN")
  createdAt        DateTime @default(now())
}

// ─────────────────────── Audit & Notifications ───────────────────

model AuditLog {
  id        String   @id @default(uuid())
  labId     String?
  lab       Lab?     @relation(fields: [labId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([labId])
  @@index([entity, entityId])
}

model Notification {
  id        String   @id @default(uuid())
  labId     String?
  lab       Lab?     @relation(fields: [labId], references: [id])
  userId    String?
  channel   String
  event     String
  payload   Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([labId])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}

// ─────────────────── Document Control ────────────────────────────

model LabDocument {
  id          String    @id @default(uuid())
  labId       String
  lab         Lab       @relation(fields: [labId], references: [id])
  docNumber   String
  title       String
  category    String
  revision    String    @default("00")
  status      String    @default("ACTIVE")
  content     String?
  approvedBy  String?
  approvedAt  DateTime?
  reviewDueAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([labId])
}

// ─────────────────── Internal Audit ──────────────────────────────

model InternalAudit {
  id            String         @id @default(uuid())
  labId         String
  lab           Lab            @relation(fields: [labId], references: [id])
  auditNumber   String
  plannedDate   DateTime
  conductedDate DateTime?
  auditor       String
  scope         String
  status        String         @default("PLANNED")
  findings      AuditFinding[]
  createdAt     DateTime       @default(now())

  @@index([labId])
}

model AuditFinding {
  id          String        @id @default(uuid())
  auditId     String
  audit       InternalAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  clause      String
  category    String
  description String
  rootCause   String?
  correction  String?
  status      String        @default("OPEN")
  dueDate     DateTime?
  closedAt    DateTime?
}

// ─────────────────── Module 8: Instrument images ─────────────────
// Photographs captured around a calibration job (before/after/damage/
// accessories). Stored as base64 data-URLs. Scalar job/instrument links keep
// the model self-contained.
model InstrumentImage {
  id           String   @id @default(uuid())
  labId        String
  jobId        String?
  instrumentId String?
  category     String   // BEFORE, AFTER, DAMAGE, ACCESSORY
  fileName     String
  fileType     String?
  fileData     String   // data:<mime>;base64,<…>
  remarks      String?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([labId])
  @@index([jobId])
  @@index([instrumentId])
}

// ─────────────────── Module 9: Complaint management ──────────────
model Complaint {
  id             String    @id @default(uuid())
  labId          String
  complaintNo    String
  customerId     String?
  certificateId  String?
  subject        String?
  description    String
  rootCause      String?
  investigation  String?
  capa           String?
  status         String    @default("OPEN") // OPEN, INVESTIGATING, CAPA_PENDING, CLOSED
  closureRemarks String?
  closedAt       DateTime?
  raisedById     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([labId, complaintNo])
  @@index([labId])
}

// ─────────────────── Module 11: Customer feedback ────────────────
model CustomerFeedback {
  id            String   @id @default(uuid())
  labId         String
  customerId    String?
  jobId         String?
  serviceRating Int
  qualityRating Int
  tatRating     Int
  supportRating Int
  comments      String?
  createdAt     DateTime @default(now())

  @@index([labId])
  @@index([customerId])
}

// ─────────────── Module 13: Reusable formulas (config-driven) ─────
model FormulaMaster {
  id          String   @id @default(uuid())
  labId       String
  name        String
  expression  String   // e.g. "ROUND(AVERAGE(r1,r2,r3) - std, 3)"
  variables   String[] // declared variable names
  constants   Json?    // { "k": 2, "g": 9.81 }
  unit        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([labId])
}
