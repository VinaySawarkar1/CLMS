// CLMS — Calibration Laboratory Management System
// Prisma schema modeling the core of each major table group.
// Specialised engine tables (measurement points, uncertainty parameters,
// observations, etc.) are scaffolded here and extended as engines are built.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum Role {
  SUPER_ADMIN
  LAB_DIRECTOR
  QUALITY_MANAGER
  TECHNICAL_MANAGER
  CALIBRATION_ENGINEER
  REVIEWER
  DATA_ENTRY_OPERATOR
  SALES
  ACCOUNTS
  STORE_MANAGER
  CUSTOMER
  AUDITOR
}

enum JobStatus {
  RECEIVED
  WAITING
  ASSIGNED
  IN_CALIBRATION
  PENDING_REVIEW
  CORRECTION_REQUIRED
  APPROVED
  CERTIFICATE_GENERATED
  DELIVERED
  CLOSED
}

enum SignatureStage {
  ENGINEER
  REVIEWER
  TECHNICAL_MANAGER
  QUALITY_MANAGER
  FINAL_LOCK
}

enum CertificateType {
  NABL
  NON_NABL
  CALIBRATION_REPORT
  VERIFICATION_REPORT
  TEST_REPORT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

// ──────────────────────── Identity & Access ──────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(DATA_ENTRY_OPERATOR)
  isActive     Boolean  @default(true)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  permissions  UserPermission[]
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]
  engineer     Engineer?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique // e.g. "jobs.create"
  description String?
  users       UserPermission[]
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  users     User[]
  jobs      Job[]
  createdAt DateTime @default(now())
}

// ─────────────────────────── CRM ─────────────────────────────────

model Customer {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  gstin       String?
  email       String?
  phone       String?
  address     String?
  contacts    Contact[]
  instruments Instrument[]
  jobs        Job[]
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contact {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  designation String?
}

// ─────────────────────── Disciplines & Instruments ───────────────

model Discipline {
  id          String       @id @default(uuid())
  name        String       @unique // Mechanical, Electrical, Pressure, ...
  code        String       @unique
  categories  InstrumentCategory[]
  instruments Instrument[]
}

model InstrumentCategory {
  id           String       @id @default(uuid())
  name         String
  disciplineId String
  discipline   Discipline   @relation(fields: [disciplineId], references: [id])
  instruments  Instrument[]
}

model Instrument {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  disciplineId  String?
  discipline    Discipline? @relation(fields: [disciplineId], references: [id])
  categoryId    String?
  category      InstrumentCategory? @relation(fields: [categoryId], references: [id])
  name          String
  make          String?
  model         String?
  serialNumber  String?
  range         String?
  leastCount    String?
  idNumber      String?
  jobs          Job[]
  createdAt     DateTime @default(now())
}

// ─────────────────────── Master / Reference Standards ────────────

model MasterInstrument {
  id              String   @id @default(uuid())
  name            String
  idNumber        String   @unique
  make            String?
  model           String?
  serialNumber    String?
  traceability    String?
  calibrationDue  DateTime?
  location        String?
  references      ReferenceStandardOnJob[]
  createdAt       DateTime @default(now())
}

// ─────────────────────────── Jobs ────────────────────────────────

model Job {
  id           String     @id @default(uuid())
  jobNumber    String     @unique
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id])
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])
  engineerId   String?
  engineer     Engineer?  @relation(fields: [engineerId], references: [id])
  status       JobStatus  @default(RECEIVED)
  receivedAt   DateTime   @default(now())
  dueDate      DateTime?
  remarks      String?
  datasheets   Datasheet[]
  certificate  Certificate?
  references   ReferenceStandardOnJob[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ReferenceStandardOnJob {
  jobId    String
  masterId String
  job      Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  master   MasterInstrument @relation(fields: [masterId], references: [id])

  @@id([jobId, masterId])
}

// ─────────────────────── Datasheet engine ────────────────────────

model Datasheet {
  id              String        @id @default(uuid())
  jobId           String
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  templateName    String
  version         Int           @default(1)
  environmental   Json?         // temperature, humidity, pressure at calibration
  observations    Observation[]
  uncertainty     UncertaintyBudget?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Observation {
  id            String    @id @default(uuid())
  datasheetId   String
  datasheet     Datasheet @relation(fields: [datasheetId], references: [id], onDelete: Cascade)
  pointLabel    String?
  nominal       Float?
  standardValue Float?
  observedValue Float?
  correction    Float?
  error         Float?
  data          Json?     // free-form grid cells for dynamic columns/rows
}

// ─────────────────────── Uncertainty engine ──────────────────────

model UncertaintyBudget {
  id                  String  @id @default(uuid())
  datasheetId         String  @unique
  datasheet           Datasheet @relation(fields: [datasheetId], references: [id], onDelete: Cascade)
  combinedUncertainty Float?
  coverageFactor      Float?  @default(2)
  expandedUncertainty Float?
  confidenceLevel     Float?  @default(95.45)
  parameters          UncertaintyParameter[]
}

model UncertaintyParameter {
  id            String @id @default(uuid())
  budgetId      String
  budget        UncertaintyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  source        String
  type          String  // "A" | "B"
  value         Float
  distribution  String? // normal, rectangular, triangular
  divisor       Float?
  sensitivity   Float?  @default(1)
  degreesFreedom Float?
  unit          String?
}

// ─────────────────────── Certificates & signatures ───────────────

model Certificate {
  id                String          @id @default(uuid())
  jobId             String          @unique
  job               Job             @relation(fields: [jobId], references: [id])
  certificateNumber String          @unique
  type              CertificateType @default(NABL)
  issueDate         DateTime        @default(now())
  qrHash            String?
  pdfPath           String?
  isLocked          Boolean         @default(false)
  decisionRule      String?
  signatures        DigitalSignature[]
  createdAt         DateTime        @default(now())
}

model DigitalSignature {
  id            String         @id @default(uuid())
  certificateId String
  certificate   Certificate    @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  stage         SignatureStage
  signedById    String
  signedByName  String
  signatureHash String
  signedAt      DateTime       @default(now())
}

// ─────────────────────── Engineers & Tasks ───────────────────────

model Engineer {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  employeeCode  String   @unique
  skills        String[]
  authorizations String[]
  jobs          Job[]
  tasks         Task[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("PENDING") // PENDING, ASSIGNED, RUNNING, REVIEW, COMPLETED
  engineerId  String?
  engineer    Engineer? @relation(fields: [engineerId], references: [id])
  dueDate     DateTime?
  createdAt   DateTime @default(now())
}

// ─────────────────────────── Billing ─────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  status        InvoiceStatus @default(DRAFT)
  amount        Float         @default(0)
  taxAmount     Float         @default(0)
  totalAmount   Float         @default(0)
  payments      Payment[]
  issueDate     DateTime?
  createdAt     DateTime      @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  method    String?
  paidAt    DateTime @default(now())
}

// ─────────────────── Environmental & Quality (NCR/CAPA) ───────────

model EnvironmentalRecord {
  id          String   @id @default(uuid())
  location    String
  temperature Float?
  humidity    Float?
  pressure    Float?
  operator    String?
  recordedAt  DateTime @default(now())
}

model NCR {
  id          String   @id @default(uuid())
  reference   String   @unique
  description String
  status      String   @default("OPEN")
  raisedById  String?
  capa        CAPA?
  createdAt   DateTime @default(now())
}

model CAPA {
  id            String   @id @default(uuid())
  ncrId         String   @unique
  ncr           NCR      @relation(fields: [ncrId], references: [id], onDelete: Cascade)
  rootCause     String?
  correctiveAction String?
  preventiveAction String?
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
}

// ─────────────────────── Audit & Notifications ───────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // LOGIN, INSERT, UPDATE, DELETE, APPROVE, SIGNATURE, ...
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  channel   String   // EMAIL, SMS, WHATSAPP, PUSH
  event     String   // CALIBRATION_DUE, JOB_ASSIGNED, CERTIFICATE_READY, ...
  payload   Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}
