# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clms

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-secure-access-secret-here
JWT_REFRESH_SECRET=your-secure-refresh-secret-here

# Encryption key for stored secrets (generate with: openssl rand -base64 32)
ENC_SECRET=your-secure-encryption-key-here

# CORS (set to your frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com

# Redis (optional, for future queue support)
REDIS_URL=redis://localhost:6379

# MinIO / S3 Object Storage (optional)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clms-files

# Support contact (shown in notification emails)
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=+91-XXXXXXXXXX

# Portal secret
PORTAL_SECRET=your-secure-portal-secret-here
